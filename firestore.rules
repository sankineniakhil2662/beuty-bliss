rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // The studio owner's account carries a custom claim { admin: true }
    // (set via the Admin SDK). Everything privileged is gated on it.
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Services: publicly readable (the site lists them). Admin manages them.
    match /services/{serviceId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Reviews: approved reviews are public; admin reads/moderates all.
    // Public submission is NOT allowed directly — the secure /review/[token]
    // flow (Phase 4) creates reviews server-side via the Admin SDK after
    // validating the one-time token, so it bypasses these rules safely.
    match /reviews/{reviewId} {
      allow read: if resource.data.status == 'approved' || isAdmin();
      allow write: if isAdmin();
    }

    // Bookings: anyone can submit a request; only admin can read/manage.
    match /bookings/{bookingId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
