# Copy this file to `.env.local` and fill in the values, then restart `npm run dev`.
#
#   cp .env.example .env.local
#
# `.env.local` is git-ignored on purpose (it holds secrets), so it is NOT in the
# repo. Every machine / deployment needs its own copy — that's why a fresh clone
# shows "Firebase not configured" and falls back to sample data.

# ---------------------------------------------------------------------------
# Firebase web config — REQUIRED (public: these ship in the browser bundle,
# access is controlled by Firestore/Storage rules, not by hiding them).
# Firebase console → Project settings → General → Your apps → SDK setup & config
# ---------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ---------------------------------------------------------------------------
# Firebase Admin SDK — REQUIRED for admin/server features (review-token links,
# SMS notify route). SERVER ONLY + SECRET: never prefix with NEXT_PUBLIC.
# Firebase console → Project settings → Service accounts → Generate new private key
# Keep the quotes and the literal \n in the private key.
# ---------------------------------------------------------------------------
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ---------------------------------------------------------------------------
# Twilio SMS — OPTIONAL. Leave blank to disable SMS (the app no-ops gracefully).
# SERVER ONLY + SECRET.
# ---------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Sruthi's phone for new-booking alerts, E.164 (e.g. +13062415599)
ADMIN_PHONE=
