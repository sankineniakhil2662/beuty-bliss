rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // The studio owner's account carries a custom claim { admin: true }
    // (set via the Admin SDK). Everything privileged is gated on it.
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Services: publicly readable (the site lists them). Admin manages them.
    match /services/{serviceId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Reviews: approved reviews are public; admin reads/moderates all.
    // Public submission is allowed but must land as "pending" (moderated before
    // it ever shows). Phase 4 adds one-time-token verification on top of this.
    match /reviews/{reviewId} {
      allow read: if resource.data.status == 'approved' || isAdmin();
      allow create: if request.resource.data.status == 'pending'
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.rating is number
                    && request.resource.data.rating >= 1
                    && request.resource.data.rating <= 5;
      allow update, delete: if isAdmin();
    }

    // Bookings: anyone can submit a request; only admin can read/manage.
    match /bookings/{bookingId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
