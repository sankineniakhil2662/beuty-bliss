rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Public review-photo uploads, constrained to small images. Read is public
    // so approved reviews can show the photos. (The upload path includes the
    // one-time review token; the review itself is still admin-moderated.)
    match /review-uploads/{token}/{fileName} {
      allow read: if true;
      allow write: if request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Service images — publicly readable so the site can show them; only the
    // signed-in admin can upload/replace them.
    match /beauty_bliss_Services/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.admin == true
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Everything else is locked down.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
